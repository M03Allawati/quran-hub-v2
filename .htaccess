Options -Indexes
ServerSignature Off

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Block ALL backup/temp/sensitive files
<FilesMatch "\.(sql|log|env|sh|md|json|lock|bak|old|tmp|swp|orig|backup|gz|tar|zip)$">
    Require all denied
</FilesMatch>

# Block PHP in uploads
<FilesMatch "\.php$">
    <If "%{REQUEST_URI} =~ m#^/uploads/#">
        Require all denied
    </If>
</FilesMatch>

# Block direct access to includes
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^includes/ - [F,L]
</IfModule>

# Remove trailing slashes
RewriteEngine On
RewriteBase /
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

DirectoryIndex index.php

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# Cache static assets
<FilesMatch "\.(css|js|jpg|jpeg|png|gif|ico|woff2)$">
    Header set Cache-Control "max-age=86400, public"
</FilesMatch>

AddDefaultCharset UTF-8
